"""One-off repro script: call a validator's check() directly, with no
try/except around it, so Python prints the full traceback with the exact
line that broke -- the runner (app/validation/runner.py) normally catches
this and only logs the exception class name.

Usage (from backend/, with the venv python):
    venv-backend/Scripts/python.exe debug_validator.py <validator_id> <value> [param_type]

Example:
    venv-backend/Scripts/python.exe debug_validator.py ticket_open INC0001234
    venv-backend/Scripts/python.exe debug_validator.py my_validator 42 integer

Delete this file when you're done -- it's a throwaway debugging aid, not
part of the app.
"""
import sys

from app import create_app
from app.plugins.base import ParamSpec
from app.validation.registry import validator_registry

if len(sys.argv) < 3:
    print(f"Usage: {sys.argv[0]} <validator_id> <value> [param_type]")
    sys.exit(1)

validator_id = sys.argv[1]
value = sys.argv[2]
param_type = sys.argv[3] if len(sys.argv) > 3 else "string"

app = create_app()
with app.app_context():
    validator = validator_registry.get(validator_id)
    if validator is None:
        known = sorted(validator_registry._validators.keys())
        print(f"No validator registered with id={validator_id!r}. Known ids: {known}")
        sys.exit(1)

    spec = ParamSpec(name="debug_field", label="Debug Field", type=param_type)
    print(f"Calling {validator_id}.check({value!r}, spec=<type={param_type}>) ...")
    validator.check(value, spec=spec)
    print("OK -- no exception raised.")
